# Environment Configuration for MeetScribe
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080
FRONTEND_URL=http://localhost:3000

# Google Cloud Platform (Firebase)
GCP_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GCP_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GCP_BUCKET_NAME=your-storage-bucket-name

# AI Services
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# Bot Configuration (for headless Chrome)
HEADLESS=true
CHROME_PROFILE_PATH=C:\Users\YourUsername\AppData\Local\Google\Chrome\User Data\BotProfile
CHROME_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Note: Create a separate Chrome profile for the bot and log in manually once
# The bot will use this persistent session to join meetings automatically